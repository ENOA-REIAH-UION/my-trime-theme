let patch = import "patch.ncl" in

# custom: 私人配置，可扩展补丁 base 任意字段，使用函数传递避免惰性求值导致的子系列配置按键布局错位
let custom = fun base =>
  {
    preset_keyboards = {
      liuli = { import_preset = "liuli_default" },
      liuli_default =
        {
          keys | priority 1 =
            patch
              base.preset_keyboards.default.keys
              [
                { index = 30, patch = { composing | priority 1 = "Tab" } },
                { index = 31, patch = { composing | priority 1 = "" } },
                { index = 35, patch = { composing | priority 1 = "" } },
                { index = 36, patch = { composing | priority 1 = "" } },
              ]
        }
        & base.preset_keyboards.default,

      snow_qingyun = { import_preset = "snow_default" },
      snow_qingchun = { import_preset = "snow_default" },
      snow_default =
        {
          keys | priority 1 =
            patch
              base.preset_keyboards.default.keys
              [
                { index = 10, patch = { width | priority 1 = 0 } },
                { index = 19, patch = { click | priority 1 = ";" } },
                { index = 20, patch = { width | priority 1 = 0 } },
                { index = 30, patch = { composing | priority 1 = "" } },
                { index = 31, patch = { composing | priority 1 = "" } },
                { index = 32, patch = { composing | priority 1 = "" } },
                { index = 34, patch = { composing | priority 1 = "" } },
                { index = 35, patch = { composing | priority 1 = "" } },
                { index = 36, patch = { composing | priority 1 = "" } },
              ]
        }
        & base.preset_keyboards.default,
    },
  }
in

