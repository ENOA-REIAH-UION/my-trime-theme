      foreground = { style = "ic@arrow-right", padding = 14 },
      action = "right",
    },
    left = {
      foreground = { style = "ic@arrow-left", padding = 14 },
      action = "left",
    },

    buttons = [
      emoji,
      edit,
      clipboard,
      redo,
      undo,
      right,
      left,
    ],
  },

  preset_keyboards = {
    default = {
      author = " ",
      name = "26键",
      width = 10,
      ascii_mode = 0,
      reset_ascii_mode = false,
      label_transform = "uppercase",
      key_symbol_offset_x = 14,
      keys = [
        { click = "q", long_click = "`", swipe_up = "`", swipe_down = "home" },
        { click = "w", long_click = "{", swipe_up = "{" },
        { click = "e", long_click = "}", swipe_up = "}" },
        { click = "r", long_click = "[", swipe_up = "[" },
        { click = "t", long_click = "]", swipe_up = "]" },
        { click = "y", long_click = "%", swipe_up = "%" },
        { click = "u", long_click = "=", swipe_up = "=" },
        { click = "i", long_click = "|", swipe_up = "|", swipe_down = "lua_music" },
        { click = "o", long_click = "^", swipe_up = "^" },
        { click = "p", long_click = "\\", swipe_up = "\\", swipe_down = "end" },
        { width = 5 },
        { click = "a", long_click = "@", swipe_up = "@", swipe_down = "select_all" },
        { click = "s", long_click = "#", swipe_up = "#" },
        { click = "d", long_click = "~", swipe_up = "~", swipe_down = "date" },
        { click = "f", long_click = "_", swipe_up = "_", swipe_down = "time" },
        { click = "g", long_click = "&", swipe_up = "&", swipe_down = "keyboard_edit" },
        { click = "h", long_click = "-", swipe_up = "-" },
        { click = "j", long_click = "+", swipe_up = "+", swipe_down = "liquid_keyboard_clipboard" },
        { click = "k", long_click = "(", swipe_up = "(", swipe_down = "liquid_keyboard_emoji" },
        { click = "l", long_click = ")", swipe_up = ")", swipe_down = "{hint_switch}{symbol_switch}" },
        { width = 5 },
        { click = "shift_L", label_symbol = " ", long_click = "shift_L", double_click = "shift_L2", composing = "escape", swipe_down = "menu", width = 15, hilited_key_back_color = "background_enter" },
        { click = "z", long_click = "*", swipe_up = "*" },
        { click = "x", long_click = "\"", swipe_up = "\"", swipe_down = "cut" },
        { click = "c", long_click = "'", swipe_up = "'", swipe_down = "copy" },
        { click = "v", long_click = "$", swipe_up = "$", swipe_down = "paste" },
        { click = "b", long_click = ":", swipe_up = ":", swipe_down = "Tab"},
        { click = "n", long_click = "!", swipe_up = "!", swipe_down = "\n" },
        { click = "m", long_click = "?", swipe_up = "?", swipe_down = "ascii_mode_switch" },
        { click = "back_space_2", swipe_up = "clear_all", swipe_down = "delete_line", swipe_left = "Delete", width = 15 },
        { width = 15, click = "keyboard_number", swipe_up = "liquid_keyboard_ascii", swipe_down = "theme_settings", composing = "candidate_2" },
        { click = "comma", label = " ，", composing = "candidate_2", swipe_up = "zdic_search" },
        { click = "ascii_mode_switch", label_symbol = " ", long_click = "liquid_keyboard_switch", composing = "candidate_2", key_text_size = 20 },
        { click = "space", swipe_left = "left", swipe_right = "right", swipe_up = "up", swipe_down = "down", width = 30 },
        { click = "slash", composing = "candidate_1" },
        { click = "period", label = " 。", composing = "candidate_1" },
        { click = "return", label_symbol = " ", popup = ["color_switch", "theme_settings"], composing = "candidate_4", swipe_up = "Mode_switch", width = 15, key_back_color = "background_enter", key_text_color = "text_enter" },
      ],
    },
    number = {
      author = " ",
      name = "数字",
      width = 20,
      ascii_mode = 1,
      keys = [
        { click = "+", long_click = "#", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = 1 },
        { click = 2 },
        { click = 3 },
        { click = "space_2", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = "-", long_click = "%", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = 4 },
        { click = 5 },
        { click = 6 },
        { click = "=", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = "*", long_click = "u", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = 7 },
        { click = 8 },
        { click = 9 },
        { click = "back_space" },
        { click = "/", long_click = "\\", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = "keyboard_default" },
        { click = 0 },
        { click = ".", key_back_color = "background_normal", key_text_color = "text_normal" },
        { click = "return", key_back_color = "background_enter", key_text_color = "text_enter" },
      ],
    },
    edit = {
      name = "编辑",
      width = 20.25,
      height = 70,
      ascii_mode = 1,
      keys = [
        { click = "select_all" },
        { click = "ctrl_left" },
        { click = "up" },
        { click = "ctrl_right" },
        { click = "keyboard_default", width = 19 },
        { click = "cut" },
        { click = "left" },
        { click = "shift_L" },
        { click = "right" },
        { click = "space_2", width = 19 },
        { click = "copy" },
        { click = "home" },
        { click = "down" },
        { click = "end" },
        { click = "back_space", width = 19 },
        { click = "paste" },
        { click = "undo" },
        { click = "Tab" },
        { click = "redo" },
        { click = "return", width = 19 },
      ],
    },
  },

  preset_keys = {
    shift_L = { label = "Shift", preview = "⇪", functional = true, send = "Shift_L" },
    shift_L2 = shift_L & { shift_lock = "click" },
    return = { label = "Enter", preview = "↵", functional = true, send = "Return" },
    back_space = { label = "⌫", repeatable = true, functional = true, send = "BackSpace" },
    back_space_2 = back_space & { label | priority 1 = "Rol", preview | priority 1 = "⌫" },
    space = { slide_cursor = true, repeatable = false, preview = " ", functional = false, label = "_______", send = "space" },
    space_2 = { repeatable = false, label = "⎵", functional = true, send = "space" },
    escape = { label = "Esc", functional = false, send = "Escape" },
    comma = { label = ",", functional = true, send = "," },
    period = { label = ".", functional = true, slide_delete = true, send = "." },
    slash = { label = "/", functional = false, send = "/" },
    left = { label = "←", send = "Left", repeatable = true, functional = false },
    right = { label = "→", send = "Right", repeatable = true, functional = false },
    up = { label = "↑", send = "Up", repeatable = true, functional = false },
    down = { label = "↓", send = "Down", repeatable = true, functional = false },
    ctrl_left = { label = "⇦", send = "Control+Left", repeatable = true, functional = false },
    ctrl_right = { label = "⇨", send = "Control+Right", repeatable = true, functional = false },
    select_all = { label = "全选", functional = false, send = "Control+a" },
    cut = { label = "剪切", functional = false, send = "Control+x" },
    copy = { label = "复制", functional = false, send = "Control+c" },
    paste = { label = "粘贴", functional = false, send = "Control+v" },
    undo = { label = "撤销", functional = false, send = "Control+z" },
    redo = { label = "重做", functional = false, send = "Control+Shift+z" },
    home = { label = "行首", send = "Home", functional = false },
    end = { label = "行尾", send = "End", functional = false },
    page_up = { label = "上页", send = "Page_Up", functional = false },
    page_down = { label = "下页", send = "Page_Down", functional = false },
    keyboard_default = { label = "返回", functional = true, send = "Eisu_toggle", select = "default" },
    keyboard_number = { label = "?123", functional = true, send = "Eisu_toggle", select = "number" },
    keyboard_edit = { label = "edit", functional = false, send = "Eisu_toggle", select = "edit" },
    liquid_keyboard_clipboard = { label = "剪贴", send = "function", command = "liquid_keyboard", option = "剪贴" },
    liquid_keyboard_exit = liquid_keyboard_clipboard & { label | priority 1 = "返回", option | priority 1 = "-1" },
    liquid_keyboard_switch = liquid_keyboard_clipboard & { label | priority 1 = "更多", option | priority 1 = "特殊" },
    liquid_keyboard_tabs = liquid_keyboard_clipboard & { label | priority 1 = "更多", option | priority 1 = "更多" },
    liquid_keyboard_emoji = liquid_keyboard_clipboard & { label | priority 1 = "🙂", option | priority 1 = "emoji" },
    liquid_keyboard_ascii = liquid_keyboard_clipboard & { label | priority 1 = "符号", option | priority 1 = "英文", functional | priority 1 = true },
    liquid_space = { label = "回车", send = "Return" },
    liquid_back_space = back_space,
    liquid_return = space_2 & { label | priority 1 = "空格" },
    menu_keyboard = { label = "菜单", send = "function", command = "menu_keyboard" },
    ascii_mode_switch = { toggle = "ascii_mode", functional = false, send = "Mode_switch", states = ["ic@web", "ic@web"] },
    date = { label = "日期", send = "function", command = "date", option = "yyyy-MM-dd" },
    time = date & { label | priority 1 = "時間", option | priority 1 = "HH:mm:ss" },
    menu = { label = "菜单", functional = false, send = "Menu" },
    settings = { label = "设置", functional = false, send = "SETTINGS" },
    theme_settings = settings & { label | priority 1 = "主题", option | priority 1 = "theme" },
    color_switch = { label = "配色", functional = false, send = "PROG_RED" },
    hide = { label = "隐藏", functional = false, send = "BACK" },
    zdic_search = { label = "汉典", functional = false, send = "function", command = "web_search", option = "https://www.zdic.net/hans/%3$s" },
    delete_line = { label = "Del↔", functional = false, text = "{End}{Shift+Home}{Delete}" },
    clear_all = { label = "⇤", text = "{Control+End}{Control+Shift+Home}{Delete}" },
    hint_switch = { toggle = "_hide_key_hint", send = "Mode_switch", states = ["≑", "≟"] },
    symbol_switch = { toggle = "_hide_key_symbol", send = "Mode_switch", states = ["☰", "☱"] },
    candidate_1 = { label = "U", send = "function", command = "select_candidate", option = "1" },
    candidate_2 = candidate_1 & { label | priority 1 = "Su", option | priority 1 = "2" },
    candidate_3 = candidate_1 & { label | priority 1 = "Yun", option | priority 1 = "3" },
    candidate_4 = candidate_1 & { label | priority 1 = "Fi", option | priority 1 = "4" },
    lua_music = { label = "music", command = "lua", option = "music.lua" },
  },
}
in

base & custom base
